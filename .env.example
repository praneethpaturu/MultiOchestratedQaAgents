# Azure DevOps
ADO_ORG=your-organization
ADO_PROJECT=your-project
ADO_TOKEN=your-personal-access-token

# LLM API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Model Configuration (override defaults)
MODEL_ORCHESTRATOR=gpt-4o
MODEL_CLARIFIER=gpt-4o
MODEL_REQUIREMENT=gpt-4o
MODEL_TEST_DESIGN=claude-sonnet-4-20250514
MODEL_AUTOMATION=gpt-4o
MODEL_MAINTENANCE=gpt-4o
MODEL_RCA=claude-opus-4-20250514
MODEL_REVIEWER=claude-opus-4-20250514

# Playwright
BASE_URL=https://your-app.example.com
HEADLESS=true

# Memory
MEMORY_DIR=.qa-memory

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# Copilot Extension Server
PORT=3000
COPILOT_SKIP_VERIFY=false
