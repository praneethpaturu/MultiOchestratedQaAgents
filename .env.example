# ─────────────────────────────────────────────────────────────────────────
#  qa-agents environment configuration
#  Copy this file to .env and fill in real values:   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────

# ── Azure DevOps (required) ──────────────────────────────────────────────
# The pipeline reads stories from ADO and writes auto-filed bugs back.
ADO_ORG=your-organization
ADO_PROJECT=your-project
# Create a PAT with Work Items: Read & write at https://dev.azure.com/<org>/_usersSettings/tokens
ADO_TOKEN=your-personal-access-token

# ── LLM Providers ────────────────────────────────────────────────────────
# OpenAI is required (gpt-4o is the default for every agent).
OPENAI_API_KEY=sk-proj-...

# Anthropic is OPTIONAL — only needed if you set any MODEL_* below to a
# claude-* model. Leave blank to route everything through OpenAI.
ANTHROPIC_API_KEY=

# ── Model routing ────────────────────────────────────────────────────────
# Default: every agent uses gpt-4o (no Anthropic key required).
# Switch any of these to claude-sonnet-4 / claude-opus-4 if you want
# longer-context reasoning for that specific role.
MODEL_ORCHESTRATOR=gpt-4o
MODEL_CLARIFIER=gpt-4o
MODEL_REQUIREMENT=gpt-4o
MODEL_TEST_DESIGN=gpt-4o
MODEL_AUTOMATION=gpt-4o
MODEL_MAINTENANCE=gpt-4o
MODEL_RCA=gpt-4o
MODEL_REVIEWER=gpt-4o

# ── Playwright ───────────────────────────────────────────────────────────
# BASE_URL is the application under test. Each /api/run call from the
# dashboard can override this for that run.
BASE_URL=https://en.wikipedia.org
HEADLESS=true

# ── Storage ──────────────────────────────────────────────────────────────
MEMORY_DIR=.qa-memory
LOG_LEVEL=info
LOG_DIR=logs

# ── Copilot Extension server (only used by `qa-agent serve`) ─────────────
PORT=3000
COPILOT_SKIP_VERIFY=false
